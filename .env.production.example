# ============================================================
# u-blog Docker 部署环境变量示例
# 复制此文件为 .env.production，填入自己的值后使用
# ============================================================

# ---- 数据库（Docker 内部 postgres 服务） ----
DB_USERNAME=ublog
DB_PASSWORD=your_secure_password_here
DB_DATABASE=ublog

# ---- JWT 密钥（必填，请使用随机字符串） ----
JWT_SECRET=change_me_to_a_random_string

# ---- 允许的跨域来源（多个用逗号分隔） ----
CORS_ORIGIN=https://your-domain.com,https://admin.your-domain.com

# ---- 首次部署时是否初始化种子数据（首次 true，后续 false） ----
INIT_SEED_DATA=false

# ---- Node 环境 ----
NODE_ENV=production

# ---- OpenClaw AI 服务（可选） ----
OPENCLAW_URL=
OPENCLAW_TOKEN=
OPENCLAW_MODEL=default

# ---- 验证码密钥 ----
CAPTCHA_SECRET=

# ---- 加密密钥（必填，请使用随机字符串） ----
ENCRYPTION_KEY=
TRANSPORT_KEY=

# ---- 网站 URL ----
SITE_URL=https://your-domain.com

# ---- 邮件服务（可选） ----
EMAIL_USER=
EMAIL_PASS=

# ---- 360 搜索推送（可选） ----
SO360_PUSH_ENABLED=false
