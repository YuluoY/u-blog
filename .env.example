# =====================================================================
# u-blog Docker 一键部署环境变量
# 使用方法：
#   1. 运行配置向导（推荐）      →  node scripts/setup.js
#      或手动复制此文件为 .env    →  cp .env.example .env
#   2. 修改下方标注【必填】的值
#   3. 启动服务                   →  docker compose up -d
# =====================================================================

# ---- 域名与协议 ----
# 本地测试填 localhost，正式部署填真实域名
DOMAIN=localhost
# 是否启用 HTTPS（需要 SSL 证书）
ENABLE_SSL=false
# SSL 证书目录（宿主机路径，映射到容器 /etc/nginx/ssl）
SSL_DIR=./deploy/nginx/ssl
# 容器内证书文件路径（启用 SSL 时生效）
SSL_CERT=/etc/nginx/ssl/cert.crt
SSL_KEY=/etc/nginx/ssl/cert.key

# ---- 数据库（Docker 内部 PostgreSQL） ----
DB_USERNAME=ublog
DB_PASSWORD=change_me_to_a_secure_password
DB_DATABASE=ublog

# ---- JWT 密钥【必填】 ----
# 用于签发登录 Token，请使用随机字符串（建议 32+ 位）
# 生成方式：openssl rand -base64 48
JWT_SECRET=change_me_to_a_random_string

# ---- 允许的跨域来源【必填】 ----
# 多个域名用逗号分隔，改成你自己的域名
CORS_ORIGIN=https://your-domain.com,https://admin.your-domain.com

# ---- Node 环境（勿改） ----
NODE_ENV=production

# ---- 首次部署种子数据 ----
# 首次部署设 true 以初始化默认数据，之后改为 false
INIT_SEED_DATA=false

# ---- 加密密钥【必填】 ----
# 生成方式：openssl rand -hex 32
ENCRYPTION_KEY=
TRANSPORT_KEY=

# ---- 验证码密钥 ----
# 生成方式：openssl rand -hex 24
CAPTCHA_SECRET=

# ---- 网站 URL【必填】 ----
SITE_URL=https://your-domain.com

# ---- 邮件服务（可选，用于评论通知/订阅） ----
EMAIL_USER=
EMAIL_PASS=

# ---- Redis（Docker 内部，通常无需修改） ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- OpenClaw AI 网关（可选） ----
OPENCLAW_URL=
OPENCLAW_TOKEN=
OPENCLAW_MODEL=default

# ---- 360 搜索推送（可选） ----
SO360_PUSH_ENABLED=false
